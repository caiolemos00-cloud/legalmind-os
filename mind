        }
        #lm-btn-new:hover{border-color:var(--lm-green);background:linear-gradient(135deg,#112a1e,#163320);}
        #lm-btn-dashboard{
            width:100%;background:transparent;border:1px solid var(--lm-border);
            color:var(--lm-text3);padding:7px 12px;border-radius:8px;cursor:pointer;
            font-size:12px;font-weight:500;font-family:var(--lm-font);transition:all .15s;
            display:flex;align-items:center;justify-content:center;gap:6px;
        }
        #lm-btn-dashboard:hover{border-color:#79b8ff;color:var(--lm-blue);}
        #lm-btn-dashboard.act{background:var(--lm-blue-bg);border-color:var(--lm-blue);color:var(--lm-blue);}

        /* ── A-Z LIST ── */
        #lm-az-list{flex:1;overflow-y:auto;padding:4px 0 8px;}
        #lm-az-list::-webkit-scrollbar{width:3px;}
        #lm-az-list::-webkit-scrollbar-thumb{background:var(--lm-border2);border-radius:2px;}
        .lm-az-letter{
            padding:8px 14px 4px;font-size:10px;font-weight:700;
            color:var(--lm-text3);text-transform:uppercase;letter-spacing:1.5px;
            display:flex;align-items:center;gap:8px;
        }
        .lm-az-letter::after{content:'';flex:1;height:1px;background:var(--lm-border);}
        .lm-case-row{
            padding:9px 14px 9px 16px;cursor:pointer;
            display:flex;align-items:flex-start;gap:9px;
            border-left:3px solid transparent;transition:all .12s;
            position:relative;
        }
        .lm-case-row:hover{background:var(--lm-bg3);}
        .lm-case-row.sel{background:#0f2019;border-left-color:var(--lm-green);}
        .lm-case-row.active-mark .lm-cr-name::after{content:'📌';font-size:9px;margin-left:5px;vertical-align:middle;}
        .lm-cr-dot{width:6px;height:6px;border-radius:50%;background:var(--lm-amber);flex-shrink:0;margin-top:5px;}
        .lm-cr-name{font-size:12.5px;color:#b8b8b8;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;line-height:1.4;}
        .lm-case-row.sel .lm-cr-name{color:#eee;font-weight:600;}
        .lm-cr-sub{font-size:10px;color:var(--lm-text3);margin-top:2px;}
        .lm-cr-time{font-size:10px;color:var(--lm-text3);flex-shrink:0;margin-top:3px;}
        .lm-cr-prazo-badge{
            position:absolute;top:50%;right:8px;transform:translateY(-50%);
            font-size:9.5px;padding:1px 6px;border-radius:4px;font-weight:600;white-space:nowrap;
        }
        .lm-cr-prazo-badge.urgente{background:#3a1010;color:#f47c7c;border:1px solid #5a2020;}
        .lm-cr-prazo-badge.proximo{background:#2a2010;color:var(--lm-amber);border:1px solid #4a3820;}

        /* ── MAIN ── */
        #lm-main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;}

        /* ── TABS ── */
        #lm-tabs-wrapper{
            display:flex;align-items:stretch;background:var(--lm-bg3);
            border-bottom:1px solid var(--lm-border);flex-shrink:0;min-height:44px;position:relative;
        }
        #lm-tabs-arrow-l,#lm-tabs-arrow-r{
            flex-shrink:0;width:28px;background:var(--lm-bg3);border:none;cursor:pointer;
            color:var(--lm-text3);font-size:12px;display:flex;align-items:center;justify-content:center;
            transition:all .15s;z-index:2;padding:0;
        }
        #lm-tabs-arrow-l{border-right:1px solid var(--lm-border);}
        #lm-tabs-arrow-r{border-left:1px solid var(--lm-border);}
        #lm-tabs-arrow-l:hover,#lm-tabs-arrow-r:hover{background:var(--lm-bg2);color:#c8c8c8;}
        #lm-tabs-arrow-l.hidden,#lm-tabs-arrow-r.hidden{opacity:0;pointer-events:none;}
        #lm-tabs{
            display:flex;flex:1;overflow-x:auto;overflow-y:hidden;
            scroll-behavior:smooth;min-height:44px;
            -ms-overflow-style:none;scrollbar-width:none;
        }
        #lm-tabs::-webkit-scrollbar{display:none;}
        #lm-tabs-wrapper::before,#lm-tabs-wrapper::after{
            content:'';position:absolute;top:0;bottom:1px;width:24px;pointer-events:none;z-index:1;
        }
        #lm-tabs-wrapper::before{left:28px;background:linear-gradient(to right,var(--lm-bg3),transparent);}
        #lm-tabs-wrapper::after{right:28px;background:linear-gradient(to left,var(--lm-bg3),transparent);}
        #lm-tabs-wrapper.no-overflow::before,#lm-tabs-wrapper.no-overflow::after{display:none;}

        .lm-tab{
            padding:0 15px;cursor:pointer;display:flex;align-items:center;gap:6px;
            border-bottom:2px solid transparent;font-size:12.5px;color:var(--lm-text2);
            white-space:nowrap;transition:all .15s;min-height:44px;margin-bottom:-1px;
            flex-shrink:0;font-weight:400;
        }
        .lm-tab:hover{color:#c8c8c8;background:rgba(255,255,255,.03);}
        .lm-tab.act{color:#f0f0f0;font-weight:600;}
        .lm-tab-ct{
            font-size:10px;background:var(--lm-border);
            padding:1px 6px;border-radius:8px;color:var(--lm-text3);
            font-family:var(--lm-mono);font-weight:400;
        }
        .lm-tab.act .lm-tab-ct{background:rgba(78,201,176,.12);color:var(--lm-green);}

        #lm-tab-add{color:#1a4a6a;font-size:12.5px;padding:0 14px;gap:5px;border-left:1px solid var(--lm-border);font-weight:500;}
        #lm-tab-add:hover{color:var(--lm-blue);}

        /* ── CONTENT ── */
        #lm-content{flex:1;overflow-y:auto;padding:20px 24px;}
        #lm-content::-webkit-scrollbar{width:4px;}
        #lm-content::-webkit-scrollbar-thumb{background:var(--lm-border2);border-radius:2px;}

        .lm-placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:var(--lm-text3);gap:14px;text-align:center;}
        .lm-placeholder span{font-size:42px;}
        .lm-placeholder p{font-size:13.5px;color:#484848;line-height:1.8;}

        /* ── SECTION LABEL ── */
        .lm-sec-label{
            font-size:10px;text-transform:uppercase;letter-spacing:1px;
            color:var(--lm-text3);margin-bottom:14px;margin-top:4px;
            display:flex;align-items:center;gap:10px;font-weight:600;
        }
        .lm-sec-label::after{content:'';flex:1;height:1px;background:var(--lm-border);}

        /* ── CASE NAME ── */
        .lm-name-wrap{margin-bottom:20px;}
        .lm-name-lbl{font-size:11.5px;color:var(--lm-text2);font-weight:600;margin-bottom:7px;display:flex;align-items:center;gap:6px;}
        .lm-name-req{color:var(--lm-green);font-size:8px;}
        .lm-inp-name{
            background:var(--lm-bg2);border:1.5px solid var(--lm-border2);
            color:#f5f5f5;padding:11px 15px;border-radius:10px;outline:none;
            font-size:15px;font-weight:600;width:100%;box-sizing:border-box;
            font-family:var(--lm-font);transition:all .2s;
        }
        .lm-inp-name:focus{border-color:#2d6a4a;background:var(--lm-bg3);box-shadow:0 0 0 3px rgba(78,201,176,.08);}
        .lm-inp-name::placeholder{color:var(--lm-text3);font-weight:400;font-size:13px;}

        /* ── FIELD GROUPS ── */
        .lm-field-group{
            background:var(--lm-bg2);border:1px solid var(--lm-border);
            border-radius:12px;padding:16px 18px;margin-bottom:16px;
        }
        .lm-field-group-title{
            font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;
            color:var(--lm-text3);margin-bottom:14px;display:flex;align-items:center;gap:8px;
        }
        .lm-field-group-title::after{content:'';flex:1;height:1px;background:var(--lm-border);}
        .lm-g4{display:grid;grid-template-columns:2fr 1fr 1.2fr 1.2fr;gap:14px;}
        .lm-g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
        .lm-g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}

        /* ── FIELD ── */
        .lm-fld{display:flex;flex-direction:column;gap:5px;position:relative;}
        .lm-fld.full{grid-column:1/-1;}
        .lm-fld-lbl{
            font-size:11px;color:var(--lm-text2);font-weight:500;
            display:flex;align-items:center;gap:4px;
        }
        .lm-fld-filled-dot{
            width:5px;height:5px;border-radius:50%;background:var(--lm-green);
            opacity:0;transition:opacity .2s;flex-shrink:0;
        }
        .lm-inp{
            background:var(--lm-bg);border:1.5px solid var(--lm-border);
            color:#e8e8e8;padding:8px 12px;border-radius:8px;outline:none;
            font-size:13px;width:100%;box-sizing:border-box;font-family:var(--lm-font);
            transition:all .2s;
        }
        .lm-inp:focus{border-color:#2d6a4a;background:var(--lm-bg3);box-shadow:0 0 0 3px rgba(78,201,176,.07);}
        .lm-inp.filled{border-color:#1e4a30;background:#0f1e15;}
        .lm-inp.filled + .lm-fld-filled-dot,.lm-fld:has(.lm-inp.filled) .lm-fld-filled-dot{opacity:1;}
        .lm-inp::placeholder{color:#2e2e2e;font-size:12px;}
        .lm-fld-acts{position:absolute;top:-2px;right:0;display:flex;gap:2px;opacity:0;transition:opacity .12s;z-index:2;}
        .lm-fld:hover .lm-fld-acts{opacity:1;}
        .lm-fld-btn{background:var(--lm-bg);border:1px solid var(--lm-border);color:var(--lm-text3);cursor:pointer;font-size:9px;padding:1px 5px;border-radius:3px;line-height:1.8;}
        .lm-fld-btn:hover{background:var(--lm-bg3);color:#ccc;}
        .lm-fld-btn.del:hover{color:var(--lm-red);background:#2a1010;}

        /* ── AREA CARDS (Global view) ── */
        .lm-area-card{
            border:1px solid var(--lm-border);border-radius:12px;
            margin-bottom:12px;overflow:hidden;transition:border-color .15s;
        }
        .lm-area-card:hover{border-color:var(--lm-border2);}
        .lm-acard-hdr{
            padding:12px 16px;cursor:pointer;
            display:flex;align-items:center;gap:10px;
            background:var(--lm-bg2);user-select:none;transition:background .12s;
        }
        .lm-acard-hdr:hover{background:var(--lm-bg3);}
        .lm-acard-hdr.open{background:var(--lm-bg3);}
        .lm-acard-icon{font-size:17px;flex-shrink:0;}
        .lm-acard-name{font-size:13px;color:#c8c8c8;font-weight:600;flex:1;}
        .lm-acard-prog{display:flex;align-items:center;gap:8px;}
        .lm-acard-pct{font-size:11px;color:var(--lm-text3);min-width:36px;text-align:right;font-family:var(--lm-mono);}
        .lm-acard-bar{width:70px;height:3px;background:var(--lm-border);border-radius:2px;overflow:hidden;}
        .lm-acard-bar-fill{height:100%;border-radius:2px;transition:width .4s;}
        .lm-acard-chev{font-size:10px;color:var(--lm-text3);transition:transform .2s;flex-shrink:0;}
        .lm-acard-hdr.open .lm-acard-chev{transform:rotate(90deg);}
        .lm-acard-go{
            background:transparent;border:1px solid var(--lm-border);
            color:var(--lm-text3);font-size:10.5px;padding:3px 10px;
            border-radius:6px;cursor:pointer;transition:all .12s;flex-shrink:0;
            font-family:var(--lm-font);
        }
        .lm-acard-go:hover{border-color:var(--lm-blue);color:var(--lm-blue);}
        .lm-acard-body{padding:14px 16px;background:var(--lm-bg);border-top:1px solid var(--lm-border);display:none;}
        .lm-acard-body.open{display:block;}

        /* ── AREA VIEW ── */
        .lm-area-top{display:flex;align-items:center;gap:12px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--lm-border);}
        .lm-area-top-icon{font-size:24px;}
        .lm-area-top-name{font-size:17px;font-weight:700;color:#f5f5f5;flex:1;letter-spacing:-.3px;}
        .lm-area-top-btns{display:flex;gap:6px;}

        /* ── SECTION ── */
        .lm-sec{margin-bottom:22px;}
        .lm-sec-hdr{display:flex;align-items:center;gap:8px;margin-bottom:12px;}
        .lm-sec-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:#666;flex:1;}
        .lm-sec-acts{display:flex;gap:3px;opacity:0;transition:opacity .12s;}
        .lm-sec:hover .lm-sec-acts{opacity:1;}
        .lm-sec-btn{background:transparent;border:none;cursor:pointer;font-size:11px;color:var(--lm-text3);padding:2px 6px;border-radius:4px;transition:all .12s;font-family:var(--lm-font);}
        .lm-sec-btn:hover{background:var(--lm-border);color:#aaa;}
        .lm-sec-btn.del:hover{color:var(--lm-red);background:#2a1010;}
        .lm-fgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
        .lm-add-fld{
            border:1px dashed var(--lm-border);width:100%;border-radius:8px;
            padding:8px;font-size:12px;color:var(--lm-text3);background:transparent;
            cursor:pointer;transition:all .15s;font-family:var(--lm-font);margin-top:2px;
        }
        .lm-add-fld:hover{border-color:var(--lm-blue);color:var(--lm-blue);}
        .lm-add-sec{
            background:transparent;border:1px dashed var(--lm-border);
            color:var(--lm-text3);padding:9px 16px;border-radius:8px;cursor:pointer;
            font-size:12.5px;width:100%;font-family:var(--lm-font);transition:all .15s;margin-top:8px;
        }
        .lm-add-sec:hover{border-color:var(--lm-blue);color:var(--lm-blue);}

        /* ── FICHA VIVA ── */
        #lm-ficha{padding:12px 20px;border-top:1px solid var(--lm-border);flex-shrink:0;background:var(--lm-bg2);}
        .lm-ficha-hdr{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
        .lm-ficha-title{font-size:11.5px;font-weight:700;color:var(--lm-blue);text-transform:uppercase;letter-spacing:.5px;}
        .lm-ficha-hint{font-size:10.5px;color:var(--lm-text3);margin-right:auto;}
        .lm-ficha-btn{
            background:transparent;border:1px solid var(--lm-border);color:var(--lm-text3);
            cursor:pointer;font-size:11px;padding:3px 9px;border-radius:5px;
            transition:all .12s;font-family:var(--lm-font);
        }
        .lm-ficha-btn:hover{border-color:var(--lm-blue);color:var(--lm-blue);}
        #lm-ficha-ta{
            width:100%;background:var(--lm-bg);border:1.5px solid var(--lm-border);
            color:#c8c8c8;padding:10px 13px;border-radius:9px;outline:none;
            font-family:var(--lm-mono);font-size:11.5px;line-height:1.7;
            resize:vertical;box-sizing:border-box;min-height:72px;max-height:180px;transition:border .2s;
        }
        #lm-ficha-ta:focus{border-color:#1a4a7a;}
        #lm-ficha-ta::placeholder{color:var(--lm-text3);}
        #lm-wc{font-size:10px;color:var(--lm-text3);margin-top:4px;}
        .lm-ficha-pulse{border-color:#2a5a8a !important;background:var(--lm-blue-bg) !important;}

        /* ── FOOTER ── */
        #lm-footer{
            padding:10px 18px;border-top:1px solid var(--lm-border);
            display:flex;gap:6px;align-items:center;flex-shrink:0;
            background:var(--lm-bg);flex-wrap:wrap;
        }
        #lm-footer-status{flex:1;font-size:11.5px;color:var(--lm-text3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
        #lm-footer-status strong{color:var(--lm-green);}

        /* ── BUTTONS ── */
        .lm-btn{border:none;cursor:pointer;font-size:12px;padding:7px 14px;border-radius:8px;font-family:var(--lm-font);transition:all .15s;white-space:nowrap;font-weight:500;}
        .lm-btn-ghost{background:transparent;border:1px solid var(--lm-border);color:var(--lm-text2);}
        .lm-btn-ghost:hover{border-color:var(--lm-border2);color:#d0d0d0;background:var(--lm-bg3);}
        .lm-btn-save{background:#1a2a0e;border:1px solid #3a6a18;color:#90cc50;}
        .lm-btn-save:hover{background:#203414;border-color:#70b030;}
        .lm-btn-close-case{background:#261c0e;border:1px solid #4a3418;color:#c08040;}
        .lm-btn-close-case:hover{background:#302010;border-color:#c08040;}
        .lm-btn-danger{background:#261010;border:1px solid #4a1c1c;color:#c06060;}
        .lm-btn-danger:hover{border-color:var(--lm-red);color:var(--lm-red);}
        .lm-btn-primary{background:linear-gradient(135deg,#0a2e18,#0c3c1e);border:1px solid #246040;color:var(--lm-green);font-weight:600;}
        .lm-btn-primary:hover{background:linear-gradient(135deg,#0c3c1e,#0e4c26);border-color:var(--lm-green);box-shadow:0 2px 14px rgba(78,201,176,.18);}
        .lm-btn-import{background:var(--lm-blue-bg);border:1px solid #1e3a5a;color:var(--lm-blue);}
        .lm-btn-import:hover{border-color:var(--lm-blue);}
        .lm-btn-master{background:linear-gradient(135deg,#180d32,#220c42);border:1px solid #4a2480;color:var(--lm-purple);font-weight:600;}
        .lm-btn-master:hover{border-color:var(--lm-purple);box-shadow:0 2px 14px rgba(197,134,192,.15);}
        .lm-btn-inject{background:linear-gradient(135deg,#1a1a0a,#2a2a0e);border:1px solid #4a4a18;color:var(--lm-amber);}
        .lm-btn-inject:hover{border-color:var(--lm-amber);}

        /* ── OVERLAY / MODAL ── */
        .lm-ov{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:100020;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(2px);}
        .lm-modal{
            background:#181818;border:1px solid #353535;border-radius:16px;
            padding:24px 28px;min-width:380px;max-width:720px;width:94vw;
            max-height:90vh;overflow-y:auto;
            box-shadow:0 32px 100px rgba(0,0,0,.95);
            display:flex;flex-direction:column;gap:16px;
        }
        .lm-modal::-webkit-scrollbar{width:4px;}
        .lm-modal::-webkit-scrollbar-thumb{background:var(--lm-border2);border-radius:2px;}
        .lm-modal h3{margin:0;font-size:15px;font-weight:700;color:#f5f5f5;letter-spacing:-.2px;}
        .lm-modal p{margin:0;font-size:12.5px;color:var(--lm-text2);line-height:1.7;}
        .lm-modal label{font-size:12px;color:var(--lm-text2);display:block;margin-bottom:5px;font-weight:500;}
        .lm-modal-acts{display:flex;gap:8px;justify-content:flex-end;}
        .lm-mstep{background:var(--lm-bg3);border:1px solid var(--lm-border);border-radius:10px;padding:16px 18px;display:flex;flex-direction:column;gap:12px;}
        .lm-mstep-num{font-size:10px;text-transform:uppercase;letter-spacing:.8px;color:#3a6a5a;font-weight:700;}
        .lm-divider{height:1px;background:var(--lm-border);}
        .lm-prompt-ta{min-height:240px;background:#0e0e0e !important;border-color:var(--lm-border) !important;font-family:var(--lm-mono) !important;font-size:11px !important;color:#a8a8a8 !important;line-height:1.6 !important;resize:vertical;}
        .lm-paste-ta{min-height:130px;background:#0e0e0e !important;border-color:var(--lm-border) !important;font-family:var(--lm-mono) !important;font-size:11px !important;color:#a8a8a8 !important;line-height:1.6 !important;resize:vertical;}
        .lm-tabs-mini{display:flex;border-bottom:1px solid var(--lm-border);margin-bottom:12px;gap:0;}
        .lm-tab-mini{padding:7px 14px;cursor:pointer;font-size:12px;color:var(--lm-text3);border-bottom:2px solid transparent;transition:all .12s;}
        .lm-tab-mini:hover{color:#aaa;}
        .lm-tab-mini.act{color:var(--lm-blue);border-bottom-color:var(--lm-blue);font-weight:600;}

        /* ── INLINE PROMPT ── */
        .lm-iprompt-ov{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:100030;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(2px);}
        .lm-iprompt-box{background:#1c1c1c;border:1px solid var(--lm-border2);border-radius:12px;padding:20px 22px;min-width:320px;max-width:420px;box-shadow:0 20px 70px rgba(0,0,0,.9);display:flex;flex-direction:column;gap:12px;}
        .lm-iprompt-lbl{font-size:13px;color:#c8c8c8;font-weight:500;}
        .lm-iprompt-acts{display:flex;gap:8px;justify-content:flex-end;}

        /* ── TOAST ── */
        #lm-toast{
            position:fixed;bottom:100px;right:96px;z-index:100000;
            background:#172e1f;border:1px solid #246040;color:var(--lm-green);
            font-size:13px;font-family:var(--lm-font);padding:9px 18px;
            border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.8);
            opacity:0;transform:translateY(10px);transition:all .25s;pointer-events:none;
        }
        #lm-toast.show{opacity:1;transform:translateY(0);}
        #lm-toast.warn{background:#261e0e;border-color:#6a4018;color:var(--lm-amber);}
        #lm-toast.error{background:#261010;border-color:#6a1818;color:var(--lm-red);}

        /* ── HIGHLIGHT ── */
        mark.lm-hl{background:#0a2e18;color:var(--lm-green);border-radius:2px;padding:0 1px;}

        /* ── TOPBAR ── */
        #lm-topbar{
            position:fixed;top:0;left:0;right:0;z-index:99995;height:36px;
            background:linear-gradient(90deg,#0a1c10,#08160c,#0a1c10);
