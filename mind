    function buildFeedBtn(){
        if(document.getElementById('lm-feed-btn')) return;
        const btn=document.createElement('button'); btn.id='lm-feed-btn';
        btn.innerHTML='📋 Alimentar Ficha';
        document.body.appendChild(btn);
