        function getContent(){
            const type=el.querySelector('input[name="inj-type"]:checked')?.value||'ficha';
            const source=activeCase||editing;
            if(!source) return '(Nenhum caso ativo)';
            const idx=wallet.findIndex(c=>c.id===source.id);
            const c=idx!==-1?wallet[idx]:source;
            if(type==='ficha') return c.fichaViva||'(Ficha Viva vazia)';
            if(type==='dados') return buildCaseDescription(c);
            if(type==='prompt') return MASTER_PROMPT_TEMPLATE.replace('{CASO_CONCRETO}',buildCaseDescription(c));
