    let _feedBtnTimer=null;
    function showFeedBtn(x,y){
        const btn=document.getElementById('lm-feed-btn'); if(!btn) return;
        const bw=180, bh=38;
        const left=Math.min(x+4,window.innerWidth-bw-12);
        const top=Math.min(y+8,window.innerHeight-bh-12);
        btn.style.left=left+'px'; btn.style.top=top+'px';
        btn.classList.add('visible');
    }
    function hideFeedBtn(){ document.getElementById('lm-feed-btn')?.classList.remove('visible'); }

    function appendToFicha(text){
        if(!activeCase){ toast('Nenhum caso ativo para alimentar.','warn'); return; }
        const idx=wallet.findIndex(c=>c.id===activeCase.id);
        const target=idx!==-1?wallet[idx]:activeCase;
        const d=new Date().toLocaleDateString('pt-BR');
        const time=new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
        const entry=`\n\n[${d} ${time}] — Trecho capturado:\n${text}`;
        target.fichaViva=(target.fichaViva||'')+entry;
        activeCase.fichaViva=target.fichaViva;
        saveActive();
        addTimeline(target,'📋 Texto capturado',text.slice(0,80)+(text.length>80?'...':''));
        if(idx!==-1){ wallet[idx]=target; saveWallet(); }
        if(editing?.id===activeCase.id){
            editing.fichaViva=target.fichaViva;
            editing.timeline=target.timeline;
            const ta=document.getElementById('lm-ficha-ta');
            const wc=document.getElementById('lm-wc');
            if(ta){ ta.value=target.fichaViva; ta.scrollTop=ta.scrollHeight; ta.classList.add('lm-ficha-pulse'); setTimeout(()=>ta.classList.remove('lm-ficha-pulse'),600); }
            if(wc) wc.textContent=wCount(target.fichaViva);
        }
        const words=text.split(/\s+/).filter(Boolean).length;
        toast(`📋 ${words} palavra${words!==1?'s':''} adicionada${words!==1?'s':''} à Ficha Viva!`);
    }

    function initSelectionListener(){
        document.addEventListener('mouseup',(e)=>{
            if(e.target.closest('#lm-panel')||e.target.closest('#lm-topbar')||e.target.closest('#lm-feed-btn')) return;
            if(!activeCase?.name){ hideFeedBtn(); return; }
            clearTimeout(_feedBtnTimer);
            _feedBtnTimer=setTimeout(()=>{
                const sel=window.getSelection();
                const text=sel?sel.toString().trim():'';
                if(text.length>10){ showFeedBtn(e.clientX,e.clientY); }
                else hideFeedBtn();
            },120);
        });
        document.addEventListener('mousedown',(e)=>{ if(!e.target.closest('#lm-feed-btn')) hideFeedBtn(); });
        document.addEventListener('keydown',(e)=>{ if(e.key==='Escape') hideFeedBtn(); });
        document.addEventListener('scroll',()=>hideFeedBtn(),{passive:true});
    }

