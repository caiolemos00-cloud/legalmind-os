    function applySchema(raw){
        const schema=parseSchema(raw);
        if(!schema){ toast('JSON inválido ou sem áreas.','error',3500); return false; }
        if(!editing){ toast('Selecione um caso antes de importar.','warn'); return false; }
        if(schema.fields){ Object.entries(schema.fields).forEach(([k,v])=>{ if(v&&!editing.fields[k]) editing.fields[k]=v; }); }
        if(editing.schema&&editing.schema.areas.length){ schema.areas.forEach(na=>{ const idx=editing.schema.areas.findIndex(a=>a.id===na.id); if(idx!==-1) editing.schema.areas[idx]=na; else editing.schema.areas.push(na); }); }
        else { editing.schema={areas:schema.areas}; }
        const lastArea=schema.areas[schema.areas.length-1];
        activeTab=lastArea?.id||editing.schema.areas[0]?.id||'global';
        addTimeline(editing,'📥 Schema importado',`${schema.areas.length} área(s)`);
        flushToWallet(); renderTabsBar(); renderContent(); renderSidebar();
        const fCount=Object.keys(schema.fields||{}).length;
        toast(`Schema aplicado! ${schema.areas.length} área(s)${fCount>0?`, ${fCount} campo(s) pré-preenchido(s)`:''}.`);
        return true;
    }

