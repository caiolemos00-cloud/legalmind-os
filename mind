        ft.addEventListener('input',()=>{ if(editing) editing.fichaViva=ft.value; wc.textContent=wCount(ft.value); });
        let fc=false;
        panel.querySelector('#lm-ficha-toggle').onclick=()=>{ fc=!fc; ft.style.display=fc?'none':''; wc.style.display=fc?'none':''; panel.querySelector('#lm-ficha-toggle').textContent=fc?'▸ Expandir':'▾ Recolher'; };
        panel.querySelector('#lm-ficha-copy').onclick=()=>{ if(!ft.value.trim()){toast('Ficha Viva vazia.','warn');return;} navigator.clipboard.writeText(ft.value).then(()=>toast('📋 Ficha Viva copiada!')); };

        panel.querySelector('#lm-btn-activate').onclick=doActivate;
        panel.querySelector('#lm-btn-save').onclick=doSave;
        panel.querySelector('#lm-btn-close-case').onclick=doCloseCase;
        panel.querySelector('#lm-btn-del').onclick=doDelete;
        panel.querySelector('#lm-btn-export').onclick=exportSchema;
        panel.querySelector('#lm-btn-import').onclick=openImportModal;
        panel.querySelector('#lm-btn-master').onclick=()=>doGerarPromptMestre();
        panel.querySelector('#lm-btn-inject').onclick=()=>openInjectModal();

        makeDraggable(panel,panel.querySelector('#lm-top'));
        renderSidebar(); renderTabsBar(); renderContent(); renderFooterStatus();
    }

    function makeDraggable(panel,handle){
        let ox=0,oy=0;
        handle.onmousedown=(e)=>{
            e.preventDefault(); ox=e.clientX-panel.getBoundingClientRect().left; oy=e.clientY-panel.getBoundingClientRect().top;
            const mm=(ev)=>{ panel.style.right='auto'; panel.style.bottom='auto'; panel.style.left=`${Math.max(0,Math.min(ev.clientX-ox,window.innerWidth-panel.offsetWidth))}px`; panel.style.top=`${Math.max(0,Math.min(ev.clientY-oy,window.innerHeight-panel.offsetHeight))}px`; };
            const mu=()=>{ document.removeEventListener('mousemove',mm); document.removeEventListener('mouseup',mu); };
            document.addEventListener('mousemove',mm); document.addEventListener('mouseup',mu);
        };
    }

    function createFab(){ const fab=document.createElement('button'); fab.id='lm-fab'; fab.title='LegalMind OS (Ctrl+Shift+C)'; fab.innerHTML='⚖️<span id="lm-fab-dot"></span>'; fab.onclick=togglePanel; document.body.appendChild(fab); updateFabDot(); }
    function updateFabDot(){ document.getElementById('lm-fab-dot')?.classList.toggle('on',!!activeCase?.name); }
    function togglePanel(){ panelOpen?hidePanel():showPanel(); }
    function showPanel(){
        panelOpen=true; activeCase=loadActive(); wallet=loadWallet();
        buildPanel();
        document.getElementById('lm-panel').classList.add('open');
        document.getElementById('lm-fab').classList.add('open');
        if(activeCase&&!editing) loadEditing(activeCase);
    }
    function hidePanel(){
        panelOpen=false;
        document.getElementById('lm-panel')?.classList.remove('open');
        document.getElementById('lm-fab')?.classList.remove('open');
    }

    document.addEventListener('keydown',(e)=>{ if(e.ctrlKey&&e.shiftKey&&e.key==='C'){e.preventDefault();togglePanel();} if(e.key==='Escape'&&panelOpen) hidePanel(); });

    function init(){
        createFab();
        buildTopbar();
        updateTopbar();
        buildFeedBtn();
        initSelectionListener();
    }
    if(document.body) init(); else document.addEventListener('DOMContentLoaded',init);

})();
