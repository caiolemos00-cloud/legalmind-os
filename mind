    `);

    function promptInline(labelText, def, cb) {
        const ov=document.createElement('div'); ov.className='lm-iprompt-ov';
        ov.innerHTML=`<div class="lm-iprompt-box"><label class="lm-iprompt-lbl">${escH(labelText)}</label><input class="lm-inp" type="text" value="${escH(def||'')}"><div class="lm-iprompt-acts"><button class="lm-btn lm-btn-ghost" id="ip-c">Cancelar</button><button class="lm-btn lm-btn-primary" id="ip-ok">OK</button></div></div>`;
        document.body.appendChild(ov);
        const inp=ov.querySelector('input'); inp.focus(); inp.select();
        const ok=()=>{ const v=inp.value.trim(); ov.remove(); if(v) cb(v); };
        ov.querySelector('#ip-ok').onclick=ok; ov.querySelector('#ip-c').onclick=()=>ov.remove();
        inp.onkeydown=(e)=>{ if(e.key==='Enter') ok(); if(e.key==='Escape') ov.remove(); };
    }

    function toast(msg, type='ok', ms=2800) {
        let el=document.getElementById('lm-toast');
        if(!el){ el=document.createElement('div'); el.id='lm-toast'; document.body.appendChild(el); }
        el.textContent=msg; el.className=`show ${type}`; clearTimeout(el._t);
        el._t=setTimeout(()=>{ el.className=''; }, ms);
    }

    function getSortName(c){ return (c.fields?.['Nome do Cliente']||c.name||'').trim(); }
    function getAreaIcons(c){ return (c.schema?.areas||[]).map(a=>a.icon||'').join(' ').trim(); }

    // ─── PRAZO ────────────────────────────────────────────────────────────────
    function getPrazoDays(prazoStr){
        if(!prazoStr) return null;
        const [d,m,a]=prazoStr.split('/').map(Number);
        if(!d||!m||!a) return null;
        const target=new Date(a,m-1,d);
        const diff=Math.ceil((target-Date.now())/(1000*60*60*24));
        return diff;
    }
    function prazoClass(days){ if(days===null) return ''; if(days<=3) return 'urgente'; if(days<=10) return 'proximo'; return 'ok'; }

    function renderSidebar() {
        const list=document.getElementById('lm-az-list'); if(!list) return;
        const q=sidebarQ.toLowerCase();
        let items=wallet.slice();
        if(q) items=items.filter(c=>getSortName(c).toLowerCase().includes(q)||(c.name||'').toLowerCase().includes(q));
        items.sort((a,b)=>getSortName(a).localeCompare(getSortName(b),'pt-BR',{sensitivity:'base'}));
        if(!items.length){
            list.innerHTML=`<div style="padding:24px 12px;text-align:center;color:var(--lm-text3);font-size:13px;">${q?'Nenhum resultado.':'<span style="font-size:30px;display:block;margin-bottom:8px;">📁</span>Nenhum caso salvo.<br><span style="color:var(--lm-green);font-size:12px;">Clique em + Novo Caso</span>'}</div>`;
            return;
        }
        const groups={};
        items.forEach(c=>{ const sn=getSortName(c); const l=sn?sn[0].toUpperCase():'#'; if(!groups[l]) groups[l]=[]; groups[l].push(c); });
        let html='';
        Object.keys(groups).sort().forEach(letter=>{
            html+=`<div class="lm-az-letter">${letter}</div>`;
            groups[letter].forEach(c=>{
                const isSel=editing?.id===c.id, isAct=activeCase?.id===c.id;
                const dn=getSortName(c)||c.name||'Sem nome';
                const icons=getAreaIcons(c);
                const days=getPrazoDays(c.prazo);
                const pc=prazoClass(days);
                let prazoHtml='';
                if(pc==='urgente') prazoHtml=`<span class="lm-cr-prazo-badge urgente">⚠ ${days}d</span>`;
                else if(pc==='proximo') prazoHtml=`<span class="lm-cr-prazo-badge proximo">${days}d</span>`;
                html+=`<div class="lm-case-row ${isSel?'sel':''} ${isAct?'active-mark':''}" data-cid="${c.id}">
                    ${isAct?'<span class="lm-cr-dot" title="Caso ativo"></span>':''}
                    <div style="flex:1;min-width:0;">
                        <div class="lm-cr-name" title="${escH(dn)}">${escH(dn)}</div>
                        ${icons?`<div class="lm-cr-sub">${escH(icons)}</div>`:''}
                    </div>
                    <div class="lm-cr-time">${timeAgo(c.ts)}</div>
                    ${prazoHtml}
                </div>`;
            });
        });
        list.innerHTML=html;
        list.querySelectorAll('.lm-case-row[data-cid]').forEach(el=>{
            el.onclick=()=>{ const c=wallet.find(x=>x.id===el.dataset.cid); if(c){ activeDashboard=false; document.getElementById('lm-dashboard')?.classList.remove('on'); document.getElementById('lm-content')?.style.setProperty('display',''); loadEditing(c); } };
        });
    }

    function loadEditing(c) {
        editing=deep(c); activeTab='global'; globalSecOpen={};
        renderAll();
    }

    function renderAll(){
        renderSidebar(); renderTabsBar(); renderContent(); renderFicha(); renderFooterStatus(); updateProgress();
    }

    // ─── TABS ─────────────────────────────────────────────────────────────────
    function renderTabsBar() {
        const wrapper=document.getElementById('lm-tabs-wrapper'); if(!wrapper) return;
        if(!editing){ wrapper.innerHTML=''; return; }

        const f=editing.fields, areas=editing.schema?.areas||[];
        const gFilled=GLOBAL_FIELDS.filter(gf=>f[gf.id]).length;

        let tabsHtml=`<div class="lm-tab ${activeTab==='global'?'act':''}" data-tab="global" style="${activeTab==='global'?'border-bottom-color:var(--lm-green);':''}">
            <span>🗂</span> Global <span class="lm-tab-ct">${gFilled}/${GLOBAL_FIELDS.length}</span></div>`;

        // Timeline tab
        const tlCount=(editing.timeline||[]).length;
        tabsHtml+=`<div class="lm-tab ${activeTab==='_timeline'?'act':''}" data-tab="_timeline" style="${activeTab==='_timeline'?'border-bottom-color:var(--lm-amber);':''}">
            ⏱ Timeline <span class="lm-tab-ct">${tlCount}</span></div>`;

        areas.forEach(area=>{
            const tot=area.sections.reduce((n,s)=>n+s.fields.length,0);
            const fil=area.sections.reduce((n,s)=>n+s.fields.filter(fld=>!!f[fld.id]).length,0);
            const isA=activeTab===area.id;
            tabsHtml+=`<div class="lm-tab ${isA?'act':''}" data-tab="${area.id}" style="${isA?`border-bottom-color:${area.color};`:''}">
                <span>${area.icon}</span> ${escH(area.label)}
                <span class="lm-tab-ct" style="${isA?`color:${area.color};`:''}">${fil}/${tot}</span></div>`;
        });
        tabsHtml+=`<div class="lm-tab" id="lm-tab-add" title="Adicionar nova área a este caso">＋ Área</div>`;

        wrapper.innerHTML=`
            <button id="lm-tabs-arrow-l">◀</button>
            <div id="lm-tabs">${tabsHtml}</div>
            <button id="lm-tabs-arrow-r">▶</button>`;

        const tabs=wrapper.querySelector('#lm-tabs');
        const arrowL=wrapper.querySelector('#lm-tabs-arrow-l');
        const arrowR=wrapper.querySelector('#lm-tabs-arrow-r');

        function updateArrows(){
            const hasOverflow=tabs.scrollWidth>tabs.clientWidth+4;
            wrapper.classList.toggle('no-overflow',!hasOverflow);
            arrowL.classList.toggle('hidden',tabs.scrollLeft<=4);
            arrowR.classList.toggle('hidden',tabs.scrollLeft>=tabs.scrollWidth-tabs.clientWidth-4);
        }
        arrowL.onclick=()=>{ tabs.scrollBy({left:-160,behavior:'smooth'}); };
        arrowR.onclick=()=>{ tabs.scrollBy({left:160,behavior:'smooth'}); };
        tabs.addEventListener('scroll',updateArrows,{passive:true});
        setTimeout(updateArrows,60);
        new ResizeObserver(updateArrows).observe(tabs);

        tabs.querySelectorAll('.lm-tab[data-tab]').forEach(t=>{
            t.onclick=()=>{ collectFields(); activeTab=t.dataset.tab; renderTabsBar(); renderContent(); };
        });
        tabs.querySelector('#lm-tab-add')?.addEventListener('click',()=>openAddAreaModal());
    }

    function renderContent(){
        const col=document.getElementById('lm-content'); if(!col) return;
        if(!editing){ col.innerHTML=`<div class="lm-placeholder"><span>👈</span><p>Selecione um caso na barra lateral<br>ou crie um novo clicando em<br><strong style="color:var(--lm-green);">+ Novo Caso</strong>.</p></div>`; return; }
        if(activeTab==='global') renderGlobal(col);
        else if(activeTab==='_timeline') renderTimeline(col);
        else renderArea(col);
    }

    // ─── GLOBAL ───────────────────────────────────────────────────────────────
    function renderGlobal(col){
        const f=editing.fields, areas=editing.schema?.areas||[];
        const days=getPrazoDays(editing.prazo);
        const pc=prazoClass(days);
        const daysLabel = days!==null ? `<span class="lm-prazo-days ${pc}">${days>0?days+'d restantes':days===0?'HOJE!':Math.abs(days)+'d em atraso'}</span>` : '';

        let html=`<div class="lm-name-wrap">
            <div class="lm-name-lbl">Identificação do Caso <span class="lm-name-req">●</span></div>
            <input type="text" class="lm-inp-name" id="lm-case-name" placeholder="Ex: João Silva — Aposentadoria Especial" value="${escH(editing.name||'')}">
        </div>

        <div class="lm-prazo-row">
            <label>📅 Prazo / Audiência</label>
            <input type="text" class="lm-prazo-inp" id="lm-prazo-inp" placeholder="DD/MM/AAAA" value="${escH(editing.prazo||'')}">
            ${daysLabel}
            <select class="lm-status-sel" id="lm-status-sel">
                <option value="ativo" ${editing.status==='ativo'?'selected':''}>🟢 Ativo</option>
                <option value="aguardando" ${editing.status==='aguardando'?'selected':''}>🟡 Aguardando</option>
                <option value="encerrado" ${editing.status==='encerrado'?'selected':''}>⚫ Encerrado</option>
                <option value="urgente" ${editing.status==='urgente'?'selected':''}>🔴 Urgente</option>
            </select>
        </div>

        <div class="lm-field-group">
            <div class="lm-field-group-title">👤 Dados do Cliente</div>
            <div class="lm-g4">
                ${gfv(f,'Nome do Cliente','Nome do Cliente','Nome completo')}
                ${gfv(f,'CPF','CPF','000.000.000-00')}
                ${gfv(f,'NB/Processo','NB / Processo','Nº benefício ou processo')}
                ${gfv(f,'Processo','Processo CNJ','0000000-00.0000.0.00.0000')}
            </div>
        </div>

        <div class="lm-field-group">
            <div class="lm-field-group-title">⚖️ Dados Processuais</div>
            <div class="lm-g3">
                ${gfv(f,'Vara/Comarca','Vara / Comarca','Ex: 3ª Vara Cível de SP')}
                ${gfv(f,'Cidade','Cidade','Cidade')}
                ${gfv(f,'Advogado','Advogado Responsável','Dr. Nome — OAB/UF 000.000')}
            </div>
        </div>`;

        if(areas.length){
            html+=`<div class="lm-sec-label" style="margin-top:6px;">Áreas do caso — clique para expandir</div>`;
            areas.forEach(area=>{
                const tot=area.sections.reduce((n,s)=>n+s.fields.length,0);
                const fil=area.sections.reduce((n,s)=>n+s.fields.filter(fld=>!!f[fld.id]).length,0);
                const pct=tot>0?Math.round(fil/tot*100):0, isOpen=!!globalSecOpen[area.id];
                let inlineHtml='';
                if(isOpen){
                    inlineHtml=`<div style="padding-top:4px;">
                    ${area.sections.map(sec=>`
                        <div style="margin-bottom:14px;">
                            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:${area.color}99;margin-bottom:10px;">${escH(sec.label)}</div>
                            <div class="lm-fgrid">${sec.fields.map(fld=>gfv(f,fld.id,fld.label,fld.placeholder||'')).join('')}
                            </div>
                        </div>`).join('')}
                    </div>`;
                }
                html+=`<div class="lm-area-card" style="${isOpen?`border-color:${area.color}40;`:''}">
                    <div class="lm-acard-hdr ${isOpen?'open':''}" data-toggle="${area.id}">
                        <span class="lm-acard-icon">${area.icon}</span>
                        <span class="lm-acard-name">${escH(area.label)}</span>
                        <div class="lm-acard-prog">
                            <span class="lm-acard-pct">${fil}/${tot}</span>
                            <div class="lm-acard-bar"><div class="lm-acard-bar-fill" style="width:${pct}%;background:${area.color};"></div></div>
                        </div>
                        <button class="lm-acard-go" data-goto="${area.id}">→ Abrir aba</button>
                        <span class="lm-acard-chev">▶</span>
                    </div>
                    <div class="lm-acard-body ${isOpen?'open':''}">${inlineHtml}</div>
                </div>`;
            });
        } else {
            html+=`<div style="margin-top:16px;padding:24px;border:1px dashed var(--lm-border);border-radius:12px;text-align:center;color:var(--lm-text3);font-size:13px;line-height:1.8;">
                Neste caso ainda não há áreas de campos.<br>
                <span style="font-size:12px;color:#1e4a6a;">Use <strong style="color:var(--lm-blue);">Importar JSON</strong> para adicionar campos gerados pela IA.</span>
            </div>`;
        }
        col.innerHTML=html;

        col.querySelector('#lm-case-name')?.addEventListener('input',(e)=>{ if(editing) editing.name=e.target.value; });
        col.querySelector('#lm-prazo-inp')?.addEventListener('change',(e)=>{
            if(editing){ editing.prazo=e.target.value.trim(); addTimeline(editing,'📅 Prazo definido',e.target.value.trim()); flushToWallet(); renderGlobal(col); }
        });
        col.querySelector('#lm-status-sel')?.addEventListener('change',(e)=>{
            if(editing){ editing.status=e.target.value; addTimeline(editing,'🔄 Status alterado',e.target.value); flushToWallet(); }
        });
        col.querySelectorAll('[data-toggle]').forEach(hdr=>{
            hdr.addEventListener('click',(e)=>{
                if(e.target.closest('[data-goto]')) return;
                collectFields(); const id=hdr.dataset.toggle;
                globalSecOpen[id]=!globalSecOpen[id]; renderContent();
            });
        });
        col.querySelectorAll('[data-goto]').forEach(btn=>{
            btn.addEventListener('click',(e)=>{ e.stopPropagation(); collectFields(); activeTab=btn.dataset.goto; renderTabsBar(); renderContent(); });
        });
        bindInputs(col);
    }

    // Campo com visual melhorado
    function gfv(f,id,label,ph){
        const filled=!!f[id];
        return `<div class="lm-fld">
            <div class="lm-fld-lbl"><span class="lm-fld-filled-dot" ${filled?'style="opacity:1"':''}></span>${escH(label)}</div>
            <input class="lm-inp ${filled?'filled':''}" type="text" data-field="${escH(id)}" placeholder="${escH(ph)}" value="${escH(f[id]||'')}">
        </div>`;
    }

    // ─── TIMELINE VIEW ────────────────────────────────────────────────────────
    function renderTimeline(col){
        const tl=(editing.timeline||[]);
        if(!tl.length){
            col.innerHTML=`<div class="lm-placeholder"><span>⏱</span><p>Nenhum evento registrado ainda.<br><span style="font-size:12px;color:var(--lm-text3);">Ações como salvar, ativar, adicionar prazo, capturar texto<br>serão registradas automaticamente aqui.</span></p></div>`;
            return;
        }
        const importantActions=['📌 Caso ativado','📥 Schema importado','📅 Prazo definido','⚠ Caso encerrado'];
        let html=`<div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;">
            <div style="font-size:16px;font-weight:700;color:#f5f5f5;flex:1;">⏱ Timeline do Caso</div>
            <div style="font-size:11.5px;color:var(--lm-text3);">${tl.length} evento${tl.length!==1?'s':''}</div>
            <button class="lm-btn lm-btn-ghost" id="tl-clear" style="font-size:11px;padding:5px 10px;">🗑 Limpar</button>
            <button class="lm-btn lm-btn-import" id="tl-export" style="font-size:11px;padding:5px 10px;">📤 Exportar</button>
        </div>
        <div class="lm-timeline">`;
        tl.forEach(ev=>{
            const isImp=importantActions.some(a=>ev.action.includes(a.replace(/^[^\s]+ /,'')));
            html+=`<div class="lm-tl-item ${isImp?'important':''}">
                <div class="lm-tl-content">
                    <div class="lm-tl-action">${escH(ev.action)}</div>
                    ${ev.detail?`<div class="lm-tl-detail">${escH(ev.detail)}</div>`:''}
                </div>
                <div class="lm-tl-time">${fmtDate(ev.ts)}</div>
            </div>`;
        });
        html+='</div>';
        col.innerHTML=html;
        col.querySelector('#tl-clear')?.addEventListener('click',()=>{
            if(!confirm('Limpar toda a timeline deste caso?')) return;
            editing.timeline=[]; flushToWallet(); renderTimeline(col);
            toast('Timeline limpa.','warn');
        });
        col.querySelector('#tl-export')?.addEventListener('click',()=>{
            const txt=tl.map(ev=>`[${fmtDate(ev.ts)}] ${ev.action}${ev.detail?'\n  '+ev.detail:''}`).join('\n\n');
            navigator.clipboard.writeText(txt).then(()=>toast('📤 Timeline copiada!'));
        });
    }

    // ─── AREA VIEW ────────────────────────────────────────────────────────────
    function renderArea(col){
        const area=editing.schema?.areas.find(a=>a.id===activeTab);
        if(!area){ col.innerHTML=''; return; }
        const f=editing.fields;
        let html=`<div class="lm-area-top">
            <span class="lm-area-top-icon">${area.icon}</span>
            <span class="lm-area-top-name">${escH(area.label)}</span>
            <div class="lm-area-top-btns">
                <button class="lm-btn lm-btn-ghost" id="btn-cp" style="font-size:11.5px;padding:6px 11px;">📋 Copiar</button>
                <button class="lm-btn lm-btn-ghost" id="btn-clr" style="font-size:11.5px;padding:6px 11px;color:#b06050;">🗑 Limpar</button>
                <button class="lm-btn lm-btn-ghost" id="btn-del-area" style="font-size:11.5px;padding:6px 11px;color:#906050;" title="Remover área">✕ Área</button>
            </div>
        </div>`;
        if(!area.sections.length){
            html+=`<div style="padding:20px;text-align:center;color:var(--lm-text3);font-size:13px;">Nenhuma seção. <button class="lm-add-sec" id="add-first-sec">＋ Criar Seção</button></div>`;
        } else {
            html+=area.sections.map(sec=>`
                <div class="lm-sec" data-sec="${sec.id}">
                    <div class="lm-sec-hdr">
                        <div class="lm-sec-title" style="color:${area.color}aa;">${escH(sec.label)}</div>
                        <div class="lm-sec-acts">
                            <button class="lm-sec-btn" data-ren="${sec.id}">✎</button>
                            <button class="lm-sec-btn del" data-del-sec="${sec.id}">✕</button>
                        </div>
                    </div>
                    <div class="lm-fgrid">
                        ${sec.fields.map(fld=>gfv(f,fld.id,fld.label,fld.placeholder||'')).join('')}
                        <div class="lm-fld" style="align-self:flex-end;"><button class="lm-add-fld" data-add-fld="${sec.id}">＋ Campo</button></div>
                    </div>
                </div>`).join('');
            html+=`<button class="lm-add-sec" id="add-sec-btn">＋ Nova Seção em "${escH(area.label)}"</button>`;
        }
        col.innerHTML=html;
        col.querySelector('#btn-cp')?.addEventListener('click',()=>{
            const lines=[];
            col.querySelectorAll('[data-field]').forEach(inp=>{ if(inp.value.trim()){ const l=inp.closest('.lm-fld')?.querySelector('.lm-fld-lbl')?.textContent?.trim()||inp.dataset.field; lines.push(`${l}: ${inp.value.trim()}`); } });
            if(!lines.length){ toast('Nenhum campo preenchido nesta área.','warn'); return; }
            navigator.clipboard.writeText(lines.join('\n')).then(()=>toast('📋 Campos copiados!'));
        });
        col.querySelector('#btn-clr')?.addEventListener('click',()=>{
            if(!confirm(`Limpar todos os campos de "${area.label}"?`)) return;
            col.querySelectorAll('[data-field]').forEach(inp=>{ inp.value=''; inp.classList.remove('filled'); delete editing.fields[inp.dataset.field]; });
            updateProgress(); renderTabsBar();
        });
        col.querySelector('#btn-del-area')?.addEventListener('click',()=>{
            if(!confirm(`Remover a área "${area.label}" deste caso?`)) return;
            editing.schema.areas=editing.schema.areas.filter(a=>a.id!==area.id);
            addTimeline(editing,`🗑 Área removida`,area.label);
            activeTab='global'; renderTabsBar(); renderContent();
            toast(`🗑 Área "${area.label}" removida.`,'warn');
        });
        col.querySelectorAll('[data-ren]').forEach(btn=>{ btn.onclick=(e)=>{ e.stopPropagation(); const sec=area.sections.find(s=>s.id===btn.dataset.ren); if(!sec) return; promptInline('Novo nome da seção:',sec.label,name=>{ sec.label=name; renderArea(col); renderTabsBar(); }); }; });
        col.querySelectorAll('[data-del-sec]').forEach(btn=>{ btn.onclick=(e)=>{ e.stopPropagation(); const sec=area.sections.find(s=>s.id===btn.dataset.delSec); if(!sec||!confirm(`Excluir seção "${sec.label}"?`)) return; area.sections=area.sections.filter(s=>s.id!==sec.id); renderArea(col); renderTabsBar(); }; });
        col.querySelectorAll('[data-add-fld]').forEach(btn=>{ btn.onclick=()=>{ const sec=area.sections.find(s=>s.id===btn.dataset.addFld); if(!sec) return; promptInline('Label do novo campo:','',label=>{ sec.fields.push({id:label.replace(/\s+/g,'_'),label,placeholder:''}); renderArea(col); renderTabsBar(); toast(`Campo "${label}" adicionado!`); }); }; });
        col.querySelectorAll('[data-del-fld]').forEach(btn=>{ btn.onclick=(e)=>{ e.stopPropagation(); const sec=area.sections.find(s=>s.id===btn.dataset.fldSec); const fld=sec?.fields.find(f=>f.id===btn.dataset.delFld); if(!fld||!confirm(`Remover campo "${fld.label}"?`)) return; sec.fields=sec.fields.filter(f=>f.id!==fld.id); renderArea(col); renderTabsBar(); }; });
        const addSecBtn=col.querySelector('#add-sec-btn')||col.querySelector('#add-first-sec');
        addSecBtn?.addEventListener('click',()=>{ promptInline('Nome da nova seção:','',name=>{ area.sections.push({id:'sec_'+genId(),label:name,fields:[]}); renderArea(col); renderTabsBar(); toast(`Seção "${name}" criada!`); }); });
        bindInputs(col);
    }

    function bindInputs(col){
        col.querySelectorAll('.lm-inp[data-field]').forEach(inp=>{
            inp.addEventListener('input',()=>{
                inp.classList.toggle('filled',inp.value.trim().length>0);
                // atualiza dot
                const dot=inp.closest('.lm-fld')?.querySelector('.lm-fld-filled-dot');
                if(dot) dot.style.opacity=inp.value.trim()?'1':'0';
                if(editing){ if(inp.value.trim()) editing.fields[inp.dataset.field]=inp.value.trim(); else delete editing.fields[inp.dataset.field]; }
                updateProgress(); renderTabsBar();
            });
        });
    }

    function collectFields(){
        const col=document.getElementById('lm-content'); if(!col||!editing) return;
        col.querySelectorAll('.lm-inp[data-field]').forEach(inp=>{
            if(inp.value.trim()) editing.fields[inp.dataset.field]=inp.value.trim(); else delete editing.fields[inp.dataset.field];
        });
        const ni=col.querySelector('#lm-case-name'); if(ni) editing.name=ni.value.trim();
        const pi=col.querySelector('#lm-prazo-inp'); if(pi) editing.prazo=pi.value.trim();
        const si=col.querySelector('#lm-status-sel'); if(si) editing.status=si.value;
        const ft=document.getElementById('lm-ficha-ta'); if(ft) editing.fichaViva=ft.value;
    }

    function renderFicha(){
        const ta=document.getElementById('lm-ficha-ta'), wc=document.getElementById('lm-wc'); if(!ta) return;
        ta.value=editing?.fichaViva||''; if(wc) wc.textContent=wCount(ta.value);
    }

    function updateFichaViva(content){
        const ta=document.getElementById('lm-ficha-ta'), wc=document.getElementById('lm-wc');
        if(ta){
            ta.value=content;
            ta.classList.add('lm-ficha-pulse');
            setTimeout(()=>ta.classList.remove('lm-ficha-pulse'),600);
            if(wc) wc.textContent=wCount(content);
        }
        if(editing) editing.fichaViva=content;
    }

    function appendToFichaViva(newContent){
        const current=(editing?.fichaViva||'').trimEnd();
        const updated = current ? current + '\n\n' + newContent : newContent;
        updateFichaViva(updated);
        if(editing){ editing.fichaViva=updated; flushToWallet(); }
        if(activeCase?.id===editing?.id){ activeCase.fichaViva=updated; saveActive(); }
    }

    function updateProgress(){
        if(!editing) return;
        const f=editing.fields; let tot=GLOBAL_FIELDS.length, fil=0;
        GLOBAL_FIELDS.forEach(gf=>{ if(f[gf.id]) fil++; });
        (editing.schema?.areas||[]).forEach(area=>{ area.sections.forEach(sec=>{ sec.fields.forEach(fld=>{ tot++; if(f[fld.id]) fil++; }); }); });
        const pct=tot>0?Math.round(fil/tot*100):0;
        const fill=document.getElementById('lm-prog-fill'), lbl=document.getElementById('lm-prog-lbl');
        if(fill) fill.style.width=pct+'%';
        if(lbl)  lbl.textContent=`${fil} de ${tot} campos · ${pct}%`;
    }

    function renderFooterStatus(){
        const el=document.getElementById('lm-footer-status'); if(!el) return;
        if(activeCase){ const n=activeCase.fields?.['Nome do Cliente']||activeCase.name||'—'; el.innerHTML=`📌 Caso ativo: <strong>${escH(n)}</strong>`; }
        else el.innerHTML=`Nenhum caso ativo. Selecione e clique em <strong style="color:var(--lm-green);">📌 Ativar</strong>.`;
    }

    function flushToWallet(){
        if(!editing) return;
        const idx=wallet.findIndex(c=>c.id===editing.id);
        if(idx!==-1) wallet[idx]=deep(editing); else { wallet.unshift(deep(editing)); if(wallet.length>80) wallet=wallet.slice(0,80); }
        saveWallet();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // NOVA FUNCIONALIDADE 1: DASHBOARD DE CARTEIRA
    // ═══════════════════════════════════════════════════════════════════════
    let dashFilter='todos';

    function showDashboard(){
        activeDashboard=true;
        const content=document.getElementById('lm-content');
        const dash=document.getElementById('lm-dashboard');
        if(content) content.style.display='none';
        if(dash){ dash.classList.add('on'); renderDashboardContent(); }
        document.getElementById('lm-btn-dashboard')?.classList.add('act');
    }

    function hideDashboard(){
        activeDashboard=false;
        const content=document.getElementById('lm-content');
        const dash=document.getElementById('lm-dashboard');
        if(content) content.style.display='';
        if(dash) dash.classList.remove('on');
        document.getElementById('lm-btn-dashboard')?.classList.remove('act');
    }

    function calcCasePct(c){
        const f=c.fields||{};
        let tot=GLOBAL_FIELDS.length, fil=0;
        GLOBAL_FIELDS.forEach(gf=>{ if(f[gf.id]) fil++; });
        (c.schema?.areas||[]).forEach(area=>{ area.sections.forEach(sec=>{ sec.fields.forEach(fld=>{ tot++; if(f[fld.id]) fil++; }); }); });
        return tot>0?Math.round(fil/tot*100):0;
    }

    function renderDashboardContent(){
        const dash=document.getElementById('lm-dashboard'); if(!dash) return;
        const total=wallet.length;
        const ativos=wallet.filter(c=>c.status!=='encerrado').length;
        const urgentes=wallet.filter(c=>{ const d=getPrazoDays(c.prazo); return d!==null&&d<=3; }).length;
        const comPrazo=wallet.filter(c=>c.prazo).length;

        // Filtragem
        let items=wallet.slice();
        if(dashFilter==='urgentes') items=items.filter(c=>{ const d=getPrazoDays(c.prazo); return d!==null&&d<=3; });
        else if(dashFilter==='ativos') items=items.filter(c=>c.status!=='encerrado');
        else if(dashFilter==='encerrados') items=items.filter(c=>c.status==='encerrado');

        // Ordenação: urgentes primeiro
        items.sort((a,b)=>{
            const da=getPrazoDays(a.prazo)??9999;
            const db=getPrazoDays(b.prazo)??9999;
            if(da!==db) return da-db;
            return getSortName(a).localeCompare(getSortName(b),'pt-BR');
        });

        let html=`<div class="lm-dash-header">
            <div class="lm-dash-title">📊 Dashboard da Carteira</div>
            <button class="lm-btn lm-btn-ghost" id="dash-close" style="font-size:11.5px;padding:6px 12px;">✕ Fechar</button>
        </div>
        <div class="lm-dash-stats">
            <div class="lm-stat-card"><div class="lm-stat-num">${total}</div><div class="lm-stat-lbl">Total de Casos</div></div>
            <div class="lm-stat-card"><div class="lm-stat-num" style="color:var(--lm-green);">${ativos}</div><div class="lm-stat-lbl">Casos Ativos</div></div>
            <div class="lm-stat-card"><div class="lm-stat-num" style="color:var(--lm-amber);">${comPrazo}</div><div class="lm-stat-lbl">Com Prazo</div></div>
            <div class="lm-stat-card"><div class="lm-stat-num" style="color:var(--lm-red);">${urgentes}</div><div class="lm-stat-lbl">Urgentes (≤3d)</div></div>
        </div>
        <div class="lm-dash-filter">
            <button class="lm-dash-filter-btn ${dashFilter==='todos'?'act':''}" data-f="todos">Todos (${total})</button>
            <button class="lm-dash-filter-btn ${dashFilter==='ativos'?'act':''}" data-f="ativos">Ativos (${ativos})</button>
            <button class="lm-dash-filter-btn ${dashFilter==='urgentes'?'act':''}" data-f="urgentes" style="${dashFilter==='urgentes'?'':'border-color:#4a1818;color:var(--lm-red);background:#1a0808;'}">⚠ Urgentes (${urgentes})</button>
            <button class="lm-dash-filter-btn ${dashFilter==='encerrados'?'act':''}" data-f="encerrados">Encerrados</button>
        </div>
        <div class="lm-dash-cases">`;

        if(!items.length){
            html+=`<div class="lm-dash-empty">Nenhum caso neste filtro.</div>`;
        }
        items.forEach(c=>{
            const pct=calcCasePct(c);
            const isAct=activeCase?.id===c.id;
            const icons=getAreaIcons(c)||'📁';
            const nome=getSortName(c)||c.name||'Sem nome';
            const days=getPrazoDays(c.prazo);
            const pc=prazoClass(days);
            const circumf=44*Math.PI;
            const dashoffset=circumf*(1-pct/100);
            const areas=(c.schema?.areas||[]).slice(0,4);

            let prazoHtml='';
            if(c.prazo){
                const cls=pc==='urgente'?'lm-prazo-urgente':pc==='proximo'?'lm-prazo-proximo':'';
                prazoHtml=`<div class="lm-dash-prazo">
                    <div class="lm-prazo-label">Prazo</div>
                    <div class="lm-prazo-date ${cls}">${escH(c.prazo)}${days!==null?`<br><span style="font-size:10px;">${days>0?days+'d':days===0?'hoje':Math.abs(days)+'d atraso'}</span>`:''}</div>
                </div>`;
            }

            html+=`<div class="lm-dash-case-card ${isAct?'active':''}" data-dcid="${c.id}">
                <div class="lm-dash-case-icon">${icons.split(' ')[0]||'📁'}</div>
                <div class="lm-dash-case-info">
                    <div class="lm-dash-case-name">${escH(nome)}${isAct?' 📌':''}</div>
                    <div class="lm-dash-case-meta">${c.fields?.['Processo']||c.fields?.['NB/Processo']||''} ${c.fields?.['Vara/Comarca']?'· '+c.fields['Vara/Comarca']:''}</div>
                    <div class="lm-dash-case-areas">
                        ${areas.map(a=>`<span class="lm-dash-area-tag" style="border-color:${a.color}44;color:${a.color};">${a.icon} ${escH(a.label)}</span>`).join('')}
                    </div>
                </div>
                <div class="lm-dash-prog-ring">
                    <svg width="44" height="44" viewBox="0 0 44 44">
                        <circle class="bg" cx="22" cy="22" r="18" stroke-dasharray="${circumf}"/>
