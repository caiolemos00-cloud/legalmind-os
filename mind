                let t=el.querySelector('#lm-inject-ta').value;
                const f=c.fields||{};
                t=t.replace(/\{\{Ficha Viva do Caso\}\}/g,c.fichaViva||'');
                t=t.replace(/\{\{([^}]+)\}\}/g,(_,k)=>f[k.trim()]||`{{${k}}}`);
                return t;
            }
            return '';
        }

        function updatePreviewTip(){
            const tip=el.querySelector('#lm-inject-preview-tip');
            const type=el.querySelector('input[name="inj-type"]:checked')?.value;
            const msgs={
                ficha:'Será injetada a Ficha Viva do Caso no campo de chat da IA.',
                dados:'Serão injetados todos os campos preenchidos do caso formatados.',
                prompt:'Será injetado o Prompt Mestre completo com todos os dados.',
                custom:'Seu texto com variáveis {{...}} substituídas pelos valores do caso.'
            };
            if(tip) tip.textContent=msgs[type]||'';
        }

        el.querySelector('#inj-preview').onclick=()=>{
            const content=getContent();
            const tip=el.querySelector('#lm-inject-preview-tip');
            if(tip){ tip.textContent=content.slice(0,400)+(content.length>400?'...':''); }
        };

        el.querySelector('#inj-copy').onclick=()=>{
            navigator.clipboard.writeText(getContent()).then(()=>toast('📋 Conteúdo copiado!'));
        };

        el.querySelector('#inj-inject').onclick=()=>{
            const content=getContent();
            const plat=detectPlatform();
            let injected=false;

            if(plat){
                const el2=document.querySelector(plat.selector);
                if(el2){
                    if(plat.type==='contenteditable'){
                        el2.focus();
                        el2.innerHTML='';
                        document.execCommand('insertText',false,content);
                        if(!el2.textContent.trim()) el2.textContent=content;
                        injected=true;
                    } else if(plat.type==='textarea'){
                        el2.focus();
                        const nativeInputValueSetter=Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype,'value')?.set;
                        if(nativeInputValueSetter) nativeInputValueSetter.call(el2,content);
                        el2.dispatchEvent(new Event('input',{bubbles:true}));
                        el2.dispatchEvent(new Event('change',{bubbles:true}));
                        injected=true;
                    }
                }
            }

            if(injected){
                el.classList.remove('on');
                toast(`⚡ Injetado no ${plat?.name||'chat'}!`);
                addTimeline(editing||activeCase?{...activeCase}:null,'⚡ Contexto injetado',plat?.name||'IA');
            } else {
                navigator.clipboard.writeText(content).then(()=>{
                    toast('Não foi possível injetar direto. Conteúdo copiado — cole manualmente (Ctrl+V).','warn',4000);
                });
            }
        };
        updatePreviewTip();
    }

