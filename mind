    function doGerarPromptMestre(autoOpen=true){
        const source=activeCase||editing;
        if(!source){ toast('Nenhum caso ativo.','warn'); return; }
        if(editing&&editing.id===source.id) collectFields();
        const idx=wallet.findIndex(c=>c.id===source.id);
        const caseData=idx!==-1?wallet[idx]:source;
        const desc=buildCaseDescription(caseData);
        const prompt=MASTER_PROMPT_TEMPLATE.replace('{CASO_CONCRETO}',desc);
        buildMasterModal();
        const ta=document.getElementById('lm-master-ta');
        if(ta) ta.value=prompt;
        document.getElementById('lm-master-modal').classList.add('on');
        addTimeline(editing||activeCase?deep(activeCase||editing):null,'🧠 Prompt Mestre gerado','');
        navigator.clipboard.writeText(prompt).then(()=>{
            const lbl=document.getElementById('lm-master-copied');
            if(lbl){ lbl.classList.add('on'); setTimeout(()=>lbl.classList.remove('on'),2800); }
            if(autoOpen) toast('🧠 Prompt Mestre gerado e copiado!');
        }).catch(()=>{ if(autoOpen) toast('🧠 Gerado! Clique em Copiar.','warn'); });
    }

