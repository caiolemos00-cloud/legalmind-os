    // ─── PROMPT MESTRE ────────────────────────────────────────────────────────
    function buildCaseDescription(c){
        const f=c.fields||{};
        const lines=[];
        lines.push('═══════════════════════════════════════');
        lines.push('DADOS DO CASO — '+(c.name||f['Nome do Cliente']||'Sem nome'));
        lines.push('═══════════════════════════════════════');
        lines.push('');
        const globalLabels={'Nome do Cliente':'Cliente','CPF':'CPF','NB/Processo':'NB / Processo','Processo':'Processo CNJ','Vara/Comarca':'Vara / Comarca','Cidade':'Cidade','Advogado':'Advogado Responsável'};
        const globalLines=[];
        Object.entries(globalLabels).forEach(([id,label])=>{ if(f[id]) globalLines.push(`${label}: ${f[id]}`); });
        if(globalLines.length){ lines.push('── IDENTIFICAÇÃO ─────────────────────'); globalLines.forEach(l=>lines.push(l)); lines.push(''); }
        const areas=c.schema?.areas||[];
        areas.forEach(area=>{
            const areaLines=[];
            area.sections.forEach(sec=>{ const sl=sec.fields.filter(fld=>f[fld.id]).map(fld=>`${fld.label}: ${f[fld.id]}`); if(sl.length){ areaLines.push(`  [ ${sec.label} ]`); sl.forEach(l=>areaLines.push('  '+l)); } });
            if(areaLines.length){ lines.push(`── ${area.icon} ${area.label.toUpperCase()} ${'─'.repeat(Math.max(0,38-area.label.length))}`); areaLines.forEach(l=>lines.push(l)); lines.push(''); }
        });
        const ficha=(c.fichaViva||'').trim();
        if(ficha){ lines.push('── FICHA VIVA DO CASO ────────────────'); lines.push(ficha); lines.push(''); }
        lines.push('═══════════════════════════════════════');
        return lines.join('\n');
    }

