        if(clientName) preFields['Nome do Cliente']=clientName;
        const caseName=clientName||preFields['Nome do Cliente']||'';
        const nc={id:genId(),name:caseName,fields:preFields,fichaViva:fichaViva||'',ts:Date.now(),schema:{areas:schema.areas},timeline:[],prazo:null,status:'ativo'};
        addTimeline(nc,'✨ Caso criado',caseName);
        wallet.unshift(nc); saveWallet(); loadEditing(nc);
        if(!caseName) document.getElementById('lm-case-name')?.focus();
        const fCount=Object.keys(preFields).filter(k=>preFields[k]).length;
        toast(`Caso criado com ${schema.areas.length} área(s)${fCount>0?` e ${fCount} campo(s)`:''}.`);
    }

