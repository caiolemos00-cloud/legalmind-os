    function loadActive() { const v=GM_getValue(CASE_KEY,null); return v&&v.id?v:null; }
    function loadWallet() {
        const arr=GM_getValue(WALLET_KEY,[]);
        if(!Array.isArray(arr)) return [];
        return arr.map(c=>({
            id:c.id||genId(),
            name:c.name||'',
            fields:c.fields||{},
            fichaViva:c.fichaViva||'',
            ts:c.ts||Date.now(),
            schema:(c.schema&&Array.isArray(c.schema.areas))?c.schema:null,
            timeline:c.timeline||[],
            prazo:c.prazo||null,
            status:c.status||'ativo'
        }));
    }
    function saveWallet() { GM_setValue(WALLET_KEY,wallet); }
    function saveActive() { GM_setValue(CASE_KEY,activeCase); }
    function genId()  { return Date.now().toString(36)+Math.random().toString(36).slice(2,7); }
    function escH(s)  { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function deep(o)  { return JSON.parse(JSON.stringify(o)); }
    function wCount(t){ const n=(t||'').trim().split(/\s+/).filter(Boolean).length; return n+' '+(n===1?'palavra':'palavras'); }
    function timeAgo(ts){
        if(!ts)return''; const d=Date.now()-ts;
        if(d<60000)return'agora'; if(d<3600000)return Math.floor(d/60000)+'min';
        if(d<86400000)return Math.floor(d/3600000)+'h'; return Math.floor(d/86400000)+'d';
    }
    function fmtDate(ts){
        if(!ts) return '—';
        return new Date(ts).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});
    }

    // ─── TIMELINE ────────────────────────────────────────────────────────────
    function addTimeline(caseObj, action, detail=''){
        if(!caseObj) return;
        if(!caseObj.timeline) caseObj.timeline=[];
        caseObj.timeline.unshift({ id:genId(), ts:Date.now(), action, detail });
        if(caseObj.timeline.length>200) caseObj.timeline=caseObj.timeline.slice(0,200);
    }

    function parseSchema(raw){
        try{
            let t=raw.trim().replace(/^```json\s*/i,'').replace(/^```/,'').replace(/```\s*$/,'').trim();
            const p=JSON.parse(t); const s=p.schema||p;
            if(!Array.isArray(s.areas)||!s.areas.length) return null;
            const preFields = (s.fields && typeof s.fields==='object') ? s.fields : {};
            const filteredFields = {};
            Object.entries(preFields).forEach(([k,v])=>{ if(v && String(v).trim()) filteredFields[k]=String(v).trim(); });
            return {areas:s.areas, fields:filteredFields};
        }catch{return null;}
    }

